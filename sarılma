-- Değişkenler
local holding = false
local targetPlayer = nil
local weld = nil

-- En yakın oyuncuyu bul
local function findNearestPlayer()
    local char = lp.Character
    if not char then return nil end
    
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not root then return nil end
    
    local pos = root.Position
    local nearest = nil
    local nearestDist = 15  -- 15 stud mesafe
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            local pChar = player.Character
            if pChar then
                local pRoot = pChar:FindFirstChild("HumanoidRootPart") or pChar:FindFirstChild("Torso")
                if pRoot then
                    local dist = (pos - pRoot.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = player
                    end
                end
            end
        end
    end
    
    return nearest
end

-- Kucakla ve weld yap (taşıma için)
local function holdPlayer(target)
    local char = lp.Character
    local targetChar = target.Character
    
    if not char or not targetChar then return false end
    
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso")
    
    if not root or not targetRoot then return false end
    
    -- Hedefin hareketini durdur
    local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
    if targetHum then
        targetHum.PlatformStand = true  -- Hareket edemez
    end
    
    -- Weld oluştur (hedefi sana bağla)
    weld = Instance.new("Weld")
    weld.Part0 = root
    weld.Part1 = targetRoot
    weld.C0 = CFrame.new(0, 2, 2)  -- Senin arkanda veya yanında duracak (ayarla)
    weld.C1 = CFrame.new(0, 0, 0)
    weld.Parent = root
    
    return true
end

-- Bırak
local function releasePlayer()
    if weld then
        pcall(function() weld:Destroy() end)
        weld = nil
    end
    
    if targetPlayer and targetPlayer.Character then
        local hum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false  -- Hareket edebilir
        end
    end
end

-- Buton
btn.MouseButton1Click:Connect(function()
    if holding then
        -- Bırak
        releasePlayer()
        holding = false
        targetPlayer = nil
        btn.Text = "KUCAKLA"
        status.Text = "Hedef: Yok"
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    else
        -- En yakını bul ve kucakla
        local target = findNearestPlayer()
        if target then
            local success = holdPlayer(target)
            if success then
                holding = true
                targetPlayer = target
                btn.Text = "BIRAK"
                status.Text = "Taşınıyor: " .. target.Name
                btn.BackgroundColor3 = Color3.fromRGB(80, 30, 30)
            else
                status.Text = "Kucaklanamadı!"
            end
        else
            status.Text = "Yakında kimse yok!"
        end
    end
end)

