-- En yakın oyuncuyu bul
local function findNearestPlayer()
    local char = lp.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not root then return nil end
    
    local pos = root.Position
    local nearest = nil
    local nearestDist = 15
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            local pChar = player.Character
            if pChar and pChar.PrimaryPart then
                local dist = (pos - pChar.PrimaryPart.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = player
                end
            end
        end
    end
    return nearest
end

-- Yapıştır (O BANA YAPIŞIR)
local function yapistir(target)
    local char = lp.Character
    local targetChar = target.Character
    
    if not char or not targetChar then return false end
    
    local myRoot = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso")
    local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
    
    if not myRoot or not targetRoot or not targetHum then return false end
    
    -- Hedefi felç et
    targetHum.PlatformStand = true
    targetHum.AutoRotate = false
    targetHum.WalkSpeed = 0
    targetHum.JumpPower = 0
    targetRoot.Anchored = false
    targetRoot.CanCollide = false
    
    -- Eski bağlantıları temizle
    pcall(function() 
        if weld then weld:Destroy() end
        if bp then bp:Destroy() end
        if bg then bg:Destroy() end
        if heartbeatConn then heartbeatConn:Disconnect() end
    end)
    
    -- DOĞRU WELD: Part0 = ben, Part1 = hedef
    weld = Instance.new("Weld")
    weld.Part0 = myRoot      -- BEN
    weld.Part1 = targetRoot  -- HEDEF
    weld.C0 = CFrame.new(0, 0, 2)  -- Onun benim önümde durması için
    weld.C1 = CFrame.new(0, 0, 0)
    weld.Parent = myRoot
    
    -- Animasyonlu geçiş
    local tween = TweenService:Create(weld, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {C0 = CFrame.new(0, 0, 1.8)})
    tween:Play()
    
    -- Yedek sistem (BodyPosition)
    bp = Instance.new("BodyPosition")
    bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bp.P = 20000
    bp.Parent = targetRoot
    
    bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.P = 20000
    bg.Parent = targetRoot
    
    -- Heartbeat ile sürekli kontrol
    heartbeatConn = RunService.Heartbeat:Connect(function()
        if not yapisti or not targetChar or not targetChar.Parent or not char or not char.Parent then
            return
        end
        if myRoot and targetRoot then
            -- Hedefi sürekli benim önümde tut
            local targetPos = myRoot.Position + myRoot.CFrame.LookVector * 2
            bp.Position = targetPos
            bg.CFrame = myRoot.CFrame
        end
    end)
    
    return true
end

-- Çöz (ışınlama yok, olduğu yerde kalsın)
local function coz()
    yapisti = false
    
    if hedef and hedef.Character then
        local hum = hedef.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.AutoRotate = true
            hum.WalkSpeed = 16
            hum.JumpPower = 50
        end
    end
    
    pcall(function()
        if weld then 
            local tween = TweenService:Create(weld, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {C0 = weld.C0 * CFrame.new(0, 0, 0.5)})
            tween:Play()
            tween.Completed:Connect(function() pcall(function() weld:Destroy() end) end)
        end
        if bp then bp:Destroy() end
        if bg then bg:Destroy() end
        if heartbeatConn then heartbeatConn:Disconnect() end
    end)
    
    weld = nil; bp = nil; bg = nil; heartbeatConn = nil
    hedef = nil
end

