-- Değişkenler
local sitting = false
local targetPlayer = nil
local weld = nil

-- En yakın oyuncuyu bul
local function findNearestPlayer()
    local char = lp.Character
    if not char then return nil end
    
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not root then return nil end
    
    local pos = root.Position
    local nearest = nil
    local nearestDist = 15
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            local pChar = player.Character
            if pChar then
                local pRoot = pChar:FindFirstChild("HumanoidRootPart") or pChar:FindFirstChild("Torso")
                if pRoot then
                    local dist = (pos - pRoot.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = player
                    end
                end
            end
        end
    end
    
    return nearest
end

-- Kucağa oturt
local function sitOnLap(target)
    local char = lp.Character
    local targetChar = target.Character
    
    if not char or not targetChar then return false end
    
    -- Senin gövden (kucağın)
    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    -- Hedefin bel kemiği (oturması için)
    local targetHip = targetChar:FindFirstChild("LowerTorso") or targetChar:FindFirstChild("Torso")
    
    if not torso or not targetHip then return false end
    
    -- Hedefin hareketini durdur
    local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
    if targetHum then
        targetHum.PlatformStand = true
        -- Oturma animasyonu varsa dene
        targetHum.Sit = true
    end
    
    -- Önceki welds temizle
    if weld then
        pcall(function() weld:Destroy() end)
        weld = nil
    end
    
    -- Weld oluştur (hedefi kucağına oturt)
    weld = Instance.new("Weld")
    weld.Part0 = torso
    weld.Part1 = targetHip
    weld.C0 = CFrame.new(0, -1.2, 0.8)  -- Kucağında oturma pozisyonu
    weld.C1 = CFrame.new(0, 0, 0)
    weld.Parent = torso
    
    return true
end

-- Bırak
local function release()
    if weld then
        pcall(function() weld:Destroy() end)
        weld = nil
    end
    
    if targetPlayer and targetPlayer.Character then
        local hum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.Sit = false
        end
    end
end

-- Buton animasyonu
local function buttonPulse()
    local tween = TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(250, 150, 170)})
    tween:Play()
    tween.Completed:Connect(function()
        local tween2 = TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(220, 120, 140)})
        tween2:Play()
    end)
end

-- Buton tıklama
btn.MouseButton1Click:Connect(function()
    buttonPulse()
    
    if sitting then
        -- Bırak
        release()
        sitting = false
        targetPlayer = nil
        btn.Text = "💺 OTURT"
        status.Text = "👤 Hedef: Yok"
        btn.BackgroundColor3 = Color3.fromRGB(220, 120, 140)
    else
        -- En yakını bul
        local target = findNearestPlayer()
        if target then
            local success = sitOnLap(target)
            if success then
                sitting = true
                targetPlayer = target
                btn.Text = "🆓 BIRAK"
                status.Text = "👤 Kucağında: " .. target.DisplayName or target.Name
                btn.BackgroundColor3 = Color3.fromRGB(180, 80, 100)
            else
                status.Text = "❌ Oturtulamadı!"
            end
        else
            status.Text = "⚠️ Yakında kimse yok!"
        end
    end
end)

