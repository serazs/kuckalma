-- Değişkenler
local following = false
local follower = nil
local weld = nil
local sitPosition = CFrame.new(0, -2.5, 2) -- Yanında oturma pozisyonu

-- En yakın oyuncuyu bul
local function findNearestPlayer()
    local char = lp.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not root then return nil end
    
    local pos = root.Position
    local nearest = nil
    local nearestDist = 20
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            local pChar = player.Character
            if pChar then
                local pRoot = pChar:FindFirstChild("HumanoidRootPart") or pChar:FindFirstChild("Torso")
                if pRoot then
                    local dist = (pos - pRoot.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = player
                    end
                end
            end
        end
    end
    return nearest
end

-- Oturt (yanına)
local function makeSit(target)
    local char = lp.Character
    local targetChar = target.Character
    
    if not char or not targetChar then return false end
    
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso")
    local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
    
    if not root or not targetRoot or not targetHum then return false end
    
    -- Hedefi oturt
    targetHum.Sit = true
    targetHum.PlatformStand = false
    
    -- Weld ile takip etmesini sağla
    if weld then pcall(function() weld:Destroy() end) end
    
    weld = Instance.new("Weld")
    weld.Part0 = root
    weld.Part1 = targetRoot
    weld.C0 = sitPosition  -- Yanında oturma pozisyonu
    weld.C1 = CFrame.new(0, 0, 0)
    weld.Parent = root
    
    return true
end

-- Ayrıl
local function makeLeave()
    if weld then
        pcall(function() weld:Destroy() end)
        weld = nil
    end
    
    if follower and follower.Character then
        local hum = follower.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.Sit = false
            hum.PlatformStand = false
        end
    end
    
    following = false
    follower = nil
    status.Text = "HEDEF: YOK"
end

-- OTUR butonu
sitBtn.MouseButton1Click:Connect(function()
    if following then
        status.Text = "ZATEN BİRİ OTURUYOR!"
        return
    end
    
    local target = findNearestPlayer()
    if target then
        local success = makeSit(target)
        if success then
            following = true
            follower = target
            status.Text = "HEDEF: " .. target.Name .. " (OTURUYOR)"
            sitBtn.BackgroundColor3 = Color3.fromRGB(60, 120, 180)
        else
            status.Text = "OTURTULAMADI!"
        end
    else
        status.Text = "YAKINDA KİMSE YOK!"
    end
end)

