-- Değişkenler
local stuck = false
local stuckTarget = nil
local weld = nil
local bp = nil
local bg = nil
local heartbeatConn = nil

-- En yakın oyuncuyu bul
local function findNearestPlayer()
    local char = lp.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not root then return nil end
    
    local pos = root.Position
    local nearest = nil
    local nearestDist = 20
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            local pChar = player.Character
            if pChar and pChar.PrimaryPart then
                local dist = (pos - pChar.PrimaryPart.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = player
                end
            end
        end
    end
    return nearest
end

-- Yapıştır
local function stick(target)
    local char = lp.Character
    local targetChar = target.Character
    
    if not char or not targetChar then return false end
    
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Torso")
    local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
    
    if not root or not targetRoot or not targetHum then return false end
    
    -- Hedefi felç et
    targetHum.PlatformStand = true
    targetHum.AutoRotate = false
    targetHum.WalkSpeed = 0
    targetHum.JumpPower = 0
    
    -- Root'u sabitle (fiziksel)
    targetRoot.Anchored = false
    targetRoot.CanCollide = false
    
    -- Eski bağlantıları temizle
    pcall(function() 
        if weld then weld:Destroy() end
        if bp then bp:Destroy() end
        if bg then bg:Destroy() end
        if heartbeatConn then heartbeatConn:Disconnect() end
    end)
    
    -- Weld (ana bağlantı)
    weld = Instance.new("Weld")
    weld.Part0 = root
    weld.Part1 = targetRoot
    weld.C0 = positions[currentPos].pos
    weld.C1 = CFrame.new(0, 0, 0)
    weld.Parent = root
    
    -- BodyPosition (yedek)
    bp = Instance.new("BodyPosition")
    bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bp.P = 20000
    bp.Parent = targetRoot
    
    bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.P = 20000
    bg.Parent = targetRoot
    
    -- Heartbeat ile sürekli kontrol
    heartbeatConn = RunService.Heartbeat:Connect(function()
        if not stuck or not targetChar or not targetChar.Parent or not char or not char.Parent then
            return
        end
        if root and targetRoot then
            local targetPos = root.Position + (root.CFrame:VectorToWorldSpace(positions[currentPos].pos.Position))
            bp.Position = targetPos
            bg.CFrame = root.CFrame
        end
    end)
    
    return true
end

-- Çöz
local function release()
    stuck = false
    if stuckTarget and stuckTarget.Character then
        local hum = stuckTarget.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.AutoRotate = true
            hum.WalkSpeed = 16
            hum.JumpPower = 50
        end
    end
    
    pcall(function()
        if weld then weld:Destroy() end
        if bp then bp:Destroy() end
        if bg then bg:Destroy() end
        if heartbeatConn then heartbeatConn:Disconnect() end
    end)
    
    weld = nil; bp = nil; bg = nil; heartbeatConn = nil
    stuckTarget = nil
end

-- Yapıştır butonu
stickBtn.MouseButton1Click:Connect(function()
    if stuck then
        statusText.Text = "⚠️ Zaten biri yapışık!"
        return
    end
    
    local target = findNearestPlayer()
    if target then
        statusText.Text = "⏳ Yapıştırılıyor..."
        task.wait(0.1)
        local success = stick(target)
        if success then
            stuck = true
            stuckTarget = target
            targetName.Text = "HEDEF: " .. target.Name:upper()
            targetIcon.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
            statusText.Text = "✅ YAPIŞTI - " .. target.Name
            stickBtn.BackgroundColor3 = Color3.fromRGB(60, 80, 140)
        else
            statusText.Text = "❌ Yapıştırma başarısız!"
        end
    else
        statusText.Text = "⚠️ Yakında kimse yok!"
    end
end)

