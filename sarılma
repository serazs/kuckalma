-- Değişkenler
local sitting = false
local targetPlayer = nil
local weld = nil

-- En yakın oyuncuyu bul
local function findNearestPlayer()
    local char = lp.Character
    if not char then return nil end
    
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not root then return nil end
    
    local pos = root.Position
    local nearest = nil
    local nearestDist = 15
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            local pChar = player.Character
            if pChar then
                local pRoot = pChar:FindFirstChild("HumanoidRootPart") or pChar:FindFirstChild("Torso")
                if pRoot then
                    local dist = (pos - pRoot.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = player
                    end
                end
            end
        end
    end
    
    return nearest
end

-- Kucağa oturt
local function sitOnLap(target)
    local char = lp.Character
    local targetChar = target.Character
    
    if not char or not targetChar then return false end
    
    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    local targetHip = targetChar:FindFirstChild("LowerTorso") or targetChar:FindFirstChild("Torso")
    
    if not torso or not targetHip then return false end
    
    local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
    if targetHum then
        targetHum.PlatformStand = true
        targetHum.Sit = true
    end
    
    if weld then
        pcall(function() weld:Destroy() end)
        weld = nil
    end
    
    weld = Instance.new("Weld")
    weld.Part0 = torso
    weld.Part1 = targetHip
    weld.C0 = CFrame.new(0, -1.2, 0.8)
    weld.C1 = CFrame.new(0, 0, 0)
    weld.Parent = torso
    
    return true
end

-- Bırak
local function release()
    if weld then
        pcall(function() weld:Destroy() end)
        weld = nil
    end
    
    if targetPlayer and targetPlayer.Character then
        local hum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.Sit = false
        end
    end
end

-- Buton işlevi
btn.MouseButton1Click:Connect(function()
    if sitting then
        release()
        sitting = false
        targetPlayer = nil
        btn.Text = "SIT ON LAP"
        statusText.Text = "TARGET: NONE"
        statusIcon.BackgroundColor3 = Color3.fromRGB(80, 80, 90)
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 42)}):Play()
    else
        local target = findNearestPlayer()
        if target then
            local success = sitOnLap(target)
            if success then
                sitting = true
                targetPlayer = target
                btn.Text = "RELEASE"
                statusText.Text = "TARGET: " .. string.upper(target.Name)
                statusIcon.BackgroundColor3 = Color3.fromRGB(150, 200, 255)
                TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(55, 35, 42)}):Play()
            else
                statusText.Text = "TARGET: INVALID"
            end
        else
            statusText.Text = "TARGET: NOT FOUND"
        end
    end
end)

