-- En yakın oyuncuyu bul
local function findNearestPlayer()
    local char = lp.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not root then return nil end
    
    local pos = root.Position
    local nearest = nil
    local nearestDist = 15
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            local pChar = player.Character
            if pChar then
                local pRoot = pChar:FindFirstChild("HumanoidRootPart") or pChar:FindFirstChild("Torso")
                if pRoot then
                    local dist = (pos - pRoot.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = player
                    end
                end
            end
        end
    end
    return nearest
end

-- Sarılma fonksiyonu
local function hugPlayer(target)
    local char = lp.Character
    local targetChar = target.Character
    
    if not char or not targetChar then return false end
    
    -- Senin gövden
    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    -- Hedefin gövdesi
    local targetTorso = targetChar:FindFirstChild("UpperTorso") or targetChar:FindFirstChild("Torso")
    
    if not torso or not targetTorso then return false end
    
    -- Hedefin hareketini durdur
    local targetHum = targetChar:FindFirstChildOfClass("Humanoid")
    if targetHum then
        targetHum.PlatformStand = true  -- Hareket edemez
        targetHum.AutoRotate = false    -- Dönmesin
    end
    
    -- Eski welds temizle
    if weld then
        pcall(function() weld:Destroy() end)
        weld = nil
    end
    
    -- Yeni weld (sarılmak için)
    weld = Instance.new("Weld")
    weld.Part0 = torso          -- Senin gövden
    weld.Part1 = targetTorso    -- Onun gövdesi
    weld.C0 = CFrame.new(0, 0, 1.2) -- Senin pozisyonun
    weld.C1 = CFrame.new(0, 0, -1)  -- Onun pozisyonu (sana yakın)
    weld.Parent = torso
    
    -- Kolları da sarılır gibi yapalım (opsiyonel)
    local arm = char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftHand")
    local targetArm = targetChar:FindFirstChild("Right Arm") or targetChar:FindFirstChild("RightHand")
    if arm and targetArm then
        local armWeld = Instance.new("Weld")
        armWeld.Part0 = arm
        armWeld.Part1 = targetArm
        armWeld.C0 = CFrame.new(0, 0, 0)
        armWeld.C1 = CFrame.new(0, 0, 0)
        armWeld.Parent = arm
        -- Ana weld'e ekle (isteğe bağlı, şimdilik sadece gövde)
    end
    
    return true
end

-- Ayrılma
local function leaveHug()
    if weld then
        pcall(function() weld:Destroy() end)
        weld = nil
    end
    
    if hugTarget and hugTarget.Character then
        local hum = hugTarget.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.PlatformStand = false
            hum.AutoRotate = true
        end
    end
    
    hugging = false
    hugTarget = nil
    status.Text = "💔 Hedef: Yok"
    hugBtn.BackgroundColor3 = Color3.fromRGB(220, 100, 120)
    hugBtn.Text = "🤗 SARIL"
end

