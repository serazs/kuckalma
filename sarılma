-- En yakın oyuncuyu bul
local function findNearestPlayer()
    local char = lp.Character
    if not char then return nil end
    
    local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if not root then return nil end
    
    local pos = root.Position
    local nearest = nil
    local nearestDist = 20  -- 20 stud mesafe
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp then
            local pChar = player.Character
            if pChar then
                local pRoot = pChar:FindFirstChild("HumanoidRootPart") or pChar:FindFirstChild("Torso")
                if pRoot then
                    local dist = (pos - pRoot.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = player
                    end
                end
            end
        end
    end
    
    return nearest
end

-- Kucaklama fonksiyonu
local function hug(target)
    -- Önce eski welds temizle
    for _, weld in ipairs(welds) do
        pcall(function() weld:Destroy() end)
    end
    welds = {}
    
    local char = lp.Character
    local targetChar = target.Character
    
    if not char or not targetChar then return false end
    
    -- Kucaklanacak parçalar (gövde ve kollar)
    local parts = {
        {name = "Torso", targetName = "Torso"},
        {name = "UpperTorso", targetName = "UpperTorso"},
        {name = "LowerTorso", targetName = "LowerTorso"},
        {name = "Head", targetName = "Head"},
        {name = "Left Arm", targetName = "Right Arm"},  -- Sol kol sağ kola
        {name = "Right Arm", targetName = "Left Arm"},  -- Sağ kol sol kola
        {name = "LeftHand", targetName = "RightHand"},
        {name = "RightHand", targetName = "LeftHand"},
    }
    
    for _, partInfo in ipairs(parts) do
        local part = char:FindFirstChild(partInfo.name, true)
        local targetPart = targetChar:FindFirstChild(partInfo.targetName, true)
        
        if part and targetPart and part:IsA("BasePart") and targetPart:IsA("BasePart") then
            local weld = Instance.new("Weld")
            weld.Part0 = part
            weld.Part1 = targetPart
            weld.C0 = CFrame.new(0, 0, 0)  -- Hizalama
            weld.C1 = CFrame.new(0, 0, -0.5)  -- Biraz yakınlaştır
            weld.Parent = part
            table.insert(welds, weld)
        end
    end
    
    return #welds > 0
end

-- Kucaklamayı çöz
local function unHug()
    for _, weld in ipairs(welds) do
        pcall(function() weld:Destroy() end)
    end
    welds = {}
end

-- Butona tıkla
btn.MouseButton1Click:Connect(function()
    if hugging then
        -- Kucaklamayı çöz
        unHug()
        hugging = false
        btn.Text = "KUCAKLA"
        status.Text = "Hedef: Yok"
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    else
        -- En yakın oyuncuyu bul
        local target = findNearestPlayer()
        if target then
            local success = hug(target)
            if success then
                hugging = true
                targetPlayer = target
                btn.Text = "BIRAK"
                status.Text = "Hedef: " .. target.Name
                btn.BackgroundColor3 = Color3.fromRGB(80, 30, 30)
            else
                status.Text = "Kucaklanamadı!"
            end
        else
            status.Text = "Yakında kimse yok!"
        end
    end
end)

